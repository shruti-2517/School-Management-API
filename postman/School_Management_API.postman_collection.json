    {
      "name": "List Schools",
      "item": [
        {
          "name": "List Schools - Near New Delhi",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/listSchools?latitude=28.6139&longitude=77.2090",
              "host": ["{{baseUrl}}"],
              "path": ["listSchools"],
              "query": [
                { "key": "latitude",  "value": "28.6139",  "description": "New Delhi latitude" },
                { "key": "longitude", "value": "77.2090",  "description": "New Delhi longitude" }
              ]
            },
            "description": "Fetches all schools sorted by distance from New Delhi (28.6139, 77.2090).\n\nThe closest school appears first. Each result includes a distance_km field."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Data is an array', function () {",
                  "    var body = pm.response.json();",
                  "    pm.expect(body.data).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Each school has distance_km field', function () {",
                  "    var schools = pm.response.json().data;",
                  "    schools.forEach(function(school) {",
                  "        pm.expect(school).to.have.property('distance_km');",
                  "    });",
                  "});",
                  "",
                  "pm.test('Schools are sorted by distance ascending', function () {",
                  "    var schools = pm.response.json().data;",
                  "    for (var i = 1; i < schools.length; i++) {",
                  "        pm.expect(schools[i].distance_km).to.be.at.least(schools[i - 1].distance_km);",
                  "    }",
                  "});"
                ]
              }
            }
          ],
