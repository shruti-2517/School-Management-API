{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "School Management API",
    "description": "Postman collection for the School Management API.\n\nEndpoints:\n- POST /addSchool — Add a new school\n- GET /listSchools?latitude=&longitude= — List schools sorted by proximity\n- GET /health — Health check\n\nSet the baseUrl variable to your server address (default: http://localhost:3000).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Check if the server is running."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has status ok', function () {",
                  "    var body = pm.response.json();",
                  "    pm.expect(body.status).to.equal('ok');",
                  "});"
                ]
              }
            }
          ],
          "response": [
            {
              "name": "200 OK",
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/health",
                  "host": ["{{baseUrl}}"],
                  "path": ["health"]
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"status\": \"ok\",\n  \"message\": \"Server is running\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Add School",
      "item": [
        {
          "name": "Add School - Success",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Kendriya Vidyalaya No. 1\",\n  \"address\": \"Salt Lake, Kolkata, West Bengal 700064\",\n  \"latitude\": 22.5726,\n  \"longitude\": 88.3639\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/addSchool",
              "host": ["{{baseUrl}}"],
              "path": ["addSchool"]
            },
            "description": "Adds a new school. All four fields are required.\n\nFields:\n- name (string)\n- address (string)\n- latitude (number, -90 to 90)\n- longitude (number, -180 to 180)"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has success status', function () {",
                  "    var body = pm.response.json();",
                  "    pm.expect(body.status).to.equal('success');",
                  "});",
                  "",
                  "pm.test('Response contains school data with id', function () {",
                  "    var body = pm.response.json();",
                  "    pm.expect(body.data).to.be.an('object');",
                  "    pm.expect(body.data.id).to.be.a('number');",
                  "});"
                ]
              }
            }
          ],
          "response": [
            {
              "name": "201 Created",
              "originalRequest": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Kendriya Vidyalaya No. 1\",\n  \"address\": \"Salt Lake, Kolkata, West Bengal 700064\",\n  \"latitude\": 22.5726,\n  \"longitude\": 88.3639\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": { "raw": "{{baseUrl}}/addSchool", "host": ["{{baseUrl}}"], "path": ["addSchool"] }
              },
              "status": "Created",
              "code": 201,
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"status\": \"success\",\n  \"message\": \"School added successfully\",\n  \"data\": {\n    \"id\": 6,\n    \"name\": \"Kendriya Vidyalaya No. 1\",\n    \"address\": \"Salt Lake, Kolkata, West Bengal 700064\",\n    \"latitude\": 22.5726,\n    \"longitude\": 88.3639\n  }\n}"
            }
